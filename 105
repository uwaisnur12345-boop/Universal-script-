--// SERVICES
local UIS = game:GetService("UserInputService")
local Players = game:GetService("Players")
local player = Players.LocalPlayer

--// GUI SETUP
local screenGui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
screenGui.Name = "AbilityUI"

-- LOGO
local logo = Instance.new("ImageLabel", screenGui)
logo.Size = UDim2.new(0, 120, 0, 120)
logo.Position = UDim2.new(0.5, -60, 0.2, 0)
logo.BackgroundTransparency = 1
logo.Image = "rbxassetid://1234567890" -- 🔁 GANTI dengan logo kamu

-- LOADING BAR BG
local bg = Instance.new("Frame", screenGui)
bg.Size = UDim2.new(0, 300, 0, 25)
bg.Position = UDim2.new(0.5, -150, 0.4, 0)
bg.BackgroundColor3 = Color3.fromRGB(30,30,30)

-- LOADING BAR
local bar = Instance.new("Frame", bg)
bar.Size = UDim2.new(0, 0, 1, 0)
bar.BackgroundColor3 = Color3.fromRGB(0,170,255)

--// CHARACTER
local char = player.Character or player.CharacterAdded:Wait()
local humanoid = char:WaitForChild("Humanoid")
local root = char:WaitForChild("HumanoidRootPart")

--// SETTINGS
local KEY = Enum.KeyCode.I
local cooldown = false

--// LOADING FUNCTION
local function playLoading()
	bar.Size = UDim2.new(0,0,1,0)
	
	for i = 1,100 do
		bar.Size = UDim2.new(i/100,0,1,0)
		wait(0.01)
	end
end

--// SPIDER
local function spiderAbility()
	playLoading()
	humanoid.JumpPower = 120
	root.Velocity = Vector3.new(0, 80, 0)
	wait(5)
	humanoid.JumpPower = 50
end

--// INVISIBLE
local function invisibleAbility()
	playLoading()
	for _,v in pairs(char:GetDescendants()) do
		if v:IsA("BasePart") then
			v.Transparency = 1
		end
	end
	wait(5)
	for _,v in pairs(char:GetDescendants()) do
		if v:IsA("BasePart") then
			v.Transparency = 0
		end
	end
end

--// GRAVITY
local function gravityAbility()
	playLoading()
	local force = Instance.new("BodyForce")
	force.Force = Vector3.new(0, workspace.Gravity * root:GetMass() * 2, 0)
	force.Parent = root
	
	wait(5)
	force:Destroy()
end

--// KEY INPUT
UIS.InputBegan:Connect(function(input, gameProcessed)
	if gameProcessed then return end
	
	if input.KeyCode == KEY and not cooldown then
		cooldown = true
		
		local choice = math.random(1,3)
		
		if choice == 1 then
			spiderAbility()
		elseif choice == 2 then
			invisibleAbility()
		else
			gravityAbility()
		end
		
		wait(3)
		cooldown = false
	end
end)
