local player = game.Players.LocalPlayer
local mouse = player:GetMouse()
local char = player.Character or player.CharacterAdded:Wait()
local humanoidRootPart = char:WaitForChild("HumanoidRootPart")

local webActive = false
local webAttachment = nil
local bodyVelocity = nil

mouse.Button1Down:Connect(function()
    if webActive then return end
    webActive = true

    local target = mouse.Hit.p

    -- Buat attachment di udara (titik target)
    local part = Instance.new("Part")
    part.Size = Vector3.new(0.5,0.5,0.5)
    part.Anchored = true
    part.CanCollide = false
    part.Position = target
    part.Transparency = 1
    part.Parent = workspace

    webAttachment = part

    -- Tarik player ke arah target
    bodyVelocity = Instance.new("BodyVelocity")
    bodyVelocity.MaxForce = Vector3.new(100000,100000,100000)
    bodyVelocity.Velocity = (target - humanoidRootPart.Position).Unit * 100
    bodyVelocity.Parent = humanoidRootPart

    -- Efek garis web (Beam)
    local att0 = Instance.new("Attachment", humanoidRootPart)
    local att1 = Instance.new("Attachment", part)

    local beam = Instance.new("Beam")
    beam.Attachment0 = att0
    beam.Attachment1 = att1
    beam.Width0 = 0.2
    beam.Width1 = 0.2
    beam.Color = ColorSequence.new(Color3.fromRGB(255,255,255))
    beam.Parent = humanoidRootPart

    -- Hapus setelah beberapa detik
    wait(1.5)

    webActive = false
    if bodyVelocity then bodyVelocity:Destroy() end
    if beam then beam:Destroy() end
    if part then part:Destroy() end
    if att0 then att0:Destroy() end
    if att1 then att1:Destroy() end
end)
